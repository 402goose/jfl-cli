#!/bin/bash
# JFL GTM - Journal Entry Helper
# Write and query journal entries in JSONL format

set -e

WORKSPACE="${WORKSPACE:-$(pwd)}"

if [[ ! -d "$WORKSPACE/.jfl" ]]; then
  echo "❌ Not in a GTM workspace (no .jfl/ directory)"
  echo "   cd into your workspace first, or set WORKSPACE=/path/to/workspace"
  exit 1
fi

get_session_id() {
  git -C "$WORKSPACE" branch --show-current 2>/dev/null || echo "openclaw-session"
}

get_journal_file() {
  local session=$(get_session_id)
  echo "$WORKSPACE/.jfl/journal/${session}.jsonl"
}

# --- write ---

write_entry() {
  local type="$1"
  local title="$2"
  local summary="$3"
  local detail="${4:-}"
  local files="${5:-[]}"
  local status="${6:-complete}"

  if [[ -z "$type" ]] || [[ -z "$title" ]] || [[ -z "$summary" ]]; then
    echo "Usage: journal write <type> <title> <summary> [detail] [files_json] [status]"
    echo ""
    echo "Types: feature, fix, decision, milestone, discovery, session-end"
    echo "Status: complete, incomplete, blocked"
    exit 1
  fi

  local session=$(get_session_id)
  local journal_file=$(get_journal_file)
  local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%S.000Z")

  mkdir -p "$(dirname "$journal_file")"

  # Validate files is valid JSON array
  echo "$files" | jq empty 2>/dev/null || files="[]"

  local entry
  if [[ -n "$detail" ]]; then
    entry=$(jq -nc \
      --argjson v 1 \
      --arg ts "$timestamp" \
      --arg session "$session" \
      --arg type "$type" \
      --arg status "$status" \
      --arg title "$title" \
      --arg summary "$summary" \
      --arg detail "$detail" \
      --argjson files "$files" \
      '{v:$v, ts:$ts, session:$session, type:$type, status:$status, title:$title, summary:$summary, detail:$detail, files:$files}')
  else
    entry=$(jq -nc \
      --argjson v 1 \
      --arg ts "$timestamp" \
      --arg session "$session" \
      --arg type "$type" \
      --arg status "$status" \
      --arg title "$title" \
      --arg summary "$summary" \
      --argjson files "$files" \
      '{v:$v, ts:$ts, session:$session, type:$type, status:$status, title:$title, summary:$summary, files:$files}')
  fi

  echo "$entry" >> "$journal_file"

  echo "✅ Journal: [$type] $title"
  echo "   File: $journal_file"
}

# --- quick shortcuts ---

quick_entry() {
  local type="$1"
  local title="$2"
  local summary="${3:-$type completed}"
  local detail="${4:-}"

  [[ -z "$title" ]] && echo "Usage: journal $type <title> [summary] [detail]" && exit 1
  write_entry "$type" "$title" "$summary" "$detail"
}

# --- list ---

list_entries() {
  local count="${1:-10}"
  local journal_file=$(get_journal_file)

  if [[ ! -f "$journal_file" ]]; then
    echo "No journal entries for this session."
    echo "   Session: $(get_session_id)"
    echo "   Expected: $journal_file"
    return 0
  fi

  echo "Recent journal entries ($(get_session_id)):"
  echo ""
  tail -"$count" "$journal_file" | while IFS= read -r line; do
    local type=$(echo "$line" | jq -r '.type // "?"' 2>/dev/null)
    local title=$(echo "$line" | jq -r '.title // "untitled"' 2>/dev/null)
    local ts=$(echo "$line" | jq -r '.ts // ""' 2>/dev/null | cut -c1-16)
    echo "  [$type] $title  ($ts)"
  done
}

# --- list-all: across all sessions ---

list_all() {
  local count="${1:-15}"
  local journal_dir="$WORKSPACE/.jfl/journal"

  if [[ ! -d "$journal_dir" ]]; then
    echo "No journal directory."
    return 0
  fi

  echo "Recent entries (all sessions):"
  echo ""
  cat "$journal_dir"/*.jsonl 2>/dev/null | \
    jq -r 'select(.title) | "\(.ts[0:16]) [\(.type)] \(.title)"' 2>/dev/null | \
    sort | tail -"$count" | while IFS= read -r line; do
      echo "  $line"
    done
}

# --- verify ---

verify_entry_exists() {
  local journal_file=$(get_journal_file)

  if [[ ! -f "$journal_file" ]] || [[ ! -s "$journal_file" ]]; then
    echo "❌ No journal entry for this session"
    echo ""
    echo "Write one:"
    echo "  journal write session-end \"Session summary\" \"What I worked on\""
    echo "  journal feature \"What I built\""
    exit 1
  fi

  local count=$(wc -l < "$journal_file" | tr -d ' ')
  echo "✅ Journal has $count entries"
}

# --- main ---

COMMAND="${1:-}"
shift || true

case "$COMMAND" in
  write|w)          write_entry "$@" ;;
  feature|feat)     quick_entry "feature" "$@" ;;
  decision|dec)     quick_entry "decision" "$@" ;;
  fix)              quick_entry "fix" "$@" ;;
  milestone|mile)   quick_entry "milestone" "$@" ;;
  discovery|disc)   quick_entry "discovery" "$@" ;;
  list|ls)          list_entries "$@" ;;
  all)              list_all "$@" ;;
  verify|check)     verify_entry_exists ;;
  file|path)        get_journal_file ;;
  *)
    echo "JFL GTM Journal Helper"
    echo ""
    echo "Usage:"
    echo "  journal write <type> <title> <summary> [detail] [files] [status]"
    echo "  journal feature <title> [summary]    Quick feature entry"
    echo "  journal decision <title> [summary]   Quick decision entry"
    echo "  journal fix <title> [summary]        Quick fix entry"
    echo "  journal milestone <title> [summary]  Quick milestone entry"
    echo "  journal list [count]                 Recent entries (this session)"
    echo "  journal all [count]                  Recent entries (all sessions)"
    echo "  journal verify                       Check entry exists (for session end)"
    echo "  journal file                         Print journal file path"
    echo ""
    echo "Examples:"
    echo "  journal feature \"Add login endpoint\" \"OAuth2 flow with Google\""
    echo "  journal decision \"Use Fly.io\" \"Cost + simplicity over k8s\""
    echo "  journal write session-end \"Done\" \"Built auth, updated CRM\""
    exit 1
    ;;
esac
