#!/bin/bash
# JFL GTM - Session Management
# Start and end GTM sessions via jfl openclaw protocol

set -e

CONFIG_FILE="${HOME}/.openclaw/openclaw.json"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

get_default_workspace() {
  jq -r '.skills.entries["jfl-gtm"].config.default_workspace // empty' "$CONFIG_FILE" 2>/dev/null
}

get_workspace() {
  local workspace="$1"

  if [[ -n "$workspace" ]]; then
    workspace="${workspace/#\~/$HOME}"
    echo "$workspace"
    return 0
  fi

  workspace=$(get_default_workspace)
  if [[ -n "$workspace" ]]; then
    echo "Using default workspace: $workspace" >&2
    echo "$workspace"
    return 0
  fi

  echo "🔍 Discovering GTM workspaces..." >&2

  local workspaces=()
  while IFS= read -r line; do
    [[ -n "$line" ]] && workspaces+=("$line")
  done < <("$SCRIPT_DIR/discover" simple 2>/dev/null)

  if [[ ${#workspaces[@]} -eq 0 ]]; then
    echo "❌ No GTM workspaces found" >&2
    echo "   Create one with: jfl init my-project" >&2
    exit 1
  fi

  if [[ ${#workspaces[@]} -eq 1 ]]; then
    echo "Found: ${workspaces[0]}" >&2
    echo "${workspaces[0]}"
    return 0
  fi

  echo "" >&2
  local i=1
  for ws in "${workspaces[@]}"; do
    local name=$(jq -r '.name // empty' "$ws/.jfl/config.json" 2>/dev/null || basename "$ws")
    echo "  $i. $name ($ws)" >&2
    i=$((i+1))
  done
  echo "" >&2

  read -p "Select workspace (1-${#workspaces[@]}): " selection >&2

  if [[ ! "$selection" =~ ^[0-9]+$ ]] || [[ $selection -lt 1 ]] || [[ $selection -gt ${#workspaces[@]} ]]; then
    echo "Invalid selection" >&2
    exit 1
  fi

  echo "${workspaces[$((selection-1))]}"
}

verify_workspace() {
  local workspace="$1"
  [[ ! -d "$workspace" ]] && echo "❌ Path doesn't exist: $workspace" && exit 1
  [[ ! -d "$workspace/.jfl" ]] && echo "❌ Not a GTM workspace (no .jfl/): $workspace" && exit 1
  [[ ! -f "$workspace/CLAUDE.md" ]] && echo "❌ Not a GTM workspace (no CLAUDE.md): $workspace" && exit 1
}

# --- session start ---

start_session() {
  local workspace="$1"
  local agent_name="${OPENCLAW_AGENT:-openclaw}"

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  JFL GTM Session"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  cd "$workspace"
  local project_name=$(jq -r '.name // empty' .jfl/config.json 2>/dev/null || basename "$workspace")

  echo ""
  echo "📁 $project_name"
  echo "   $workspace"

  # Delegate to jfl openclaw if available
  if command -v jfl &>/dev/null; then
    echo ""
    echo "→ Starting session via jfl openclaw..."
    jfl openclaw session-start --agent "$agent_name" --gtm "$workspace" --json 2>/dev/null | {
      if command -v jq &>/dev/null; then
        jq -r '
          if .error then "❌ " + .message
          else "✅ Session: " + .session_id +
               "\n   Branch: " + .branch +
               "\n   Context Hub: " + (if .context_hub.healthy then "healthy" else "unreachable" end) +
               "\n   Auto-commit: " + (if .auto_commit.running then "running" else "off" end)
          end
        ' 2>/dev/null || cat
      else
        cat
      fi
    }
  else
    echo ""
    echo "⚠️  jfl not installed — running standalone"
    standalone_start "$workspace"
  fi

  # Sync repos if script exists
  if [[ -x "$workspace/scripts/session/session-sync.sh" ]]; then
    echo ""
    echo "→ Syncing repos..."
    "$workspace/scripts/session/session-sync.sh" 2>&1 | tail -3 || true
  fi

  # Context Hub
  echo ""
  echo "→ Context Hub..."
  local hub_url="${CONTEXT_HUB_URL:-http://localhost:4242}"
  if command -v jfl &>/dev/null; then
    jfl context-hub ensure 2>&1 | tail -2 || true
  fi
  if curl -sf "$hub_url/health" &>/dev/null; then
    echo "  ✅ Context Hub healthy ($hub_url)"
  else
    echo "  ⚠️  Context Hub not responding"
  fi

  # Dashboard
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  Dashboard"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  local roadmap="$workspace/knowledge/ROADMAP.md"
  if [[ -f "$roadmap" ]]; then
    local date_match=$(grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}' "$roadmap" | head -1)
    if [[ -n "$date_match" ]]; then
      local days=$(( ( $(date -d "$date_match" +%s 2>/dev/null || date -jf "%Y-%m-%d" "$date_match" +%s 2>/dev/null) - $(date +%s) ) / 86400 ))
      if [[ $days -gt 0 ]]; then
        echo "  🚀 ${days}d to launch ($date_match)"
      else
        echo "  🚀 $(( -days ))d past launch ($date_match)"
      fi
    fi
  fi

  if command -v jfl &>/dev/null; then
    echo ""
    echo "  Recent work:"
    jfl synopsis 24 2>/dev/null | head -8 | sed 's/^/  /' || echo "  (none)"
  fi

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  ✅ Session ready — following CLAUDE.md"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
}

standalone_start() {
  local workspace="$1"
  cd "$workspace"

  local branch="session-openclaw-$(date +%Y%m%d-%H%M)-$(openssl rand -hex 3 2>/dev/null || printf '%06x' $RANDOM)"
  git checkout -b "$branch" 2>/dev/null || true
  mkdir -p .jfl/journal
  echo "$branch" > .jfl/current-session-branch.txt

  echo "  ✅ Session branch: $branch"
}

# --- session end ---

end_session() {
  local workspace="${1:-$(pwd)}"
  workspace="${workspace/#\~/$HOME}"

  [[ ! -d "$workspace/.jfl" ]] && workspace="$(pwd)"
  [[ ! -d "$workspace/.jfl" ]] && echo "❌ Not in a GTM workspace" && exit 1

  cd "$workspace"
  local project_name=$(jq -r '.name // empty' .jfl/config.json 2>/dev/null || basename "$workspace")

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  Ending session: $project_name"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  # Check journal
  local branch=$(git branch --show-current 2>/dev/null || echo "unknown")
  local journal=".jfl/journal/${branch}.jsonl"

  if [[ ! -s "$journal" ]]; then
    echo ""
    echo "⚠️  No journal entry for this session!"
    echo "   Write one: $SCRIPT_DIR/journal write session-end \"Summary\" \"What I worked on\""
    echo ""
    read -p "End anyway? [y/N]: " confirm
    [[ ! "$confirm" =~ ^[Yy]$ ]] && echo "Aborted." && exit 1
  else
    local count=$(wc -l < "$journal" | tr -d ' ')
    echo "  ✅ Journal: $count entries"
  fi

  # Commit outstanding work
  echo "  → Committing..."
  git add -A 2>/dev/null || true
  git diff --cached --quiet 2>/dev/null || git commit -m "session: end $(date +%Y-%m-%d)" 2>/dev/null || true

  # Delegate to jfl openclaw if available
  if command -v jfl &>/dev/null; then
    jfl openclaw session-end --json 2>/dev/null | {
      if command -v jq &>/dev/null; then
        jq -r 'if .error then "  ⚠️  " + .message else "  ✅ Session ended" end' 2>/dev/null || echo "  ✅ Session ended"
      else
        echo "  ✅ Session ended"
      fi
    }
  fi

  # Push
  echo "  → Pushing..."
  git push origin "$branch" 2>/dev/null && echo "  ✅ Pushed" || echo "  ⚠️  Push failed (no remote?)"

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  ✅ Done. Context preserved for next session."
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
}

# --- session status ---

show_status() {
  if command -v jfl &>/dev/null; then
    jfl openclaw status
  else
    echo "Install jfl for full status: npm i -g just-fucking-launch"
  fi
}

# --- main ---

COMMAND="${1:-start}"
shift || true

case "$COMMAND" in
  start|init)
    workspace=$(get_workspace "$@")
    verify_workspace "$workspace"
    start_session "$workspace"
    ;;
  end|stop|done)
    end_session "$@"
    ;;
  status)
    show_status
    ;;
  *)
    echo "JFL GTM Session Management"
    echo ""
    echo "Usage:"
    echo "  session start [/path/to/workspace]  Start GTM session"
    echo "  session end [/path/to/workspace]    End session (commit, push)"
    echo "  session status                      Show session state"
    echo ""
    echo "Environment:"
    echo "  OPENCLAW_AGENT   Agent name (default: openclaw)"
    echo "  CONTEXT_HUB_URL  Context Hub URL (default: http://localhost:4242)"
    exit 1
    ;;
esac
