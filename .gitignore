# Dependencies
node_modules/

# Build output
dist/

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Test coverage
coverage/

# JFL runtime — never commit these
.jfl/logs/
.jfl/*.log
.jfl/*.pid
.jfl/memory.db

# JFL session metadata (ephemeral)
.jfl/current-session-branch.txt
.jfl/current-worktree.txt
.jfl/worktree-path.txt

# Generated peer agent files — machine-specific absolute paths, never commit
.claude/agents/peer-service-*.md

# Python bytecode and venv
*.pyc
*.pyo
__pycache__/
.venv/

# Training artifacts (machine-specific)
.jfl/train-cache/
.jfl/train-export/
.jfl/policy-weights.json
.jfl/training-meta.json
.jfl/sessions/
