# Dependencies
node_modules/

# Build output
dist/

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# JFL runtime — never commit these
.jfl/logs/
.jfl/*.log
.jfl/*.pid
.jfl/auto-commit.pid
.jfl/context-hub.pid
.jfl/.auto-merge.pid

# JFL session metadata (ephemeral, managed by session hooks)
.jfl/current-session-branch.txt
.jfl/current-worktree.txt
.jfl/worktree-path.txt

# JFL memory DB (binary, rebuilt from journal)
.jfl/memory.db
