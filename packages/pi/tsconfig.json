{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./extensions",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "../../src/lib/*.js": ["../../src/lib/*.ts"]
    }
  },
  "include": ["extensions/**/*"],
  "exclude": ["node_modules", "dist"]
}
